# ==============================================================================
# Risk Engine Environment Configuration Example (risk_engine/.env.example)
# ==============================================================================
# Copy this file to .env in the project root to configure local credentials
# and execution settings.
# ==============================================================================

# ------------------------------------------------------------------------------
# Dispatch Mode
# Options: "dry_run" or "live"
# Default: "dry_run"
# Rationale: Defaults to dry_run so running tests or local development loops
# will never trigger real Twilio charges or SMS/WhatsApp/Voice call spam.
# Set to "live" to dispatch actual calls and messages.
# ------------------------------------------------------------------------------
DISPATCH_MODE=dry_run

# ------------------------------------------------------------------------------
# Twilio Gateway Credentials
# Find these in your Twilio Console dashboard: https://twilio.com/console
# NEVER commit real account secrets or auth tokens into git repositories.
# ------------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# ------------------------------------------------------------------------------
# Phone & WhatsApp Configuration
# TWILIO_PHONE_NUMBER: Purchased Twilio active phone number for Voice calls.
# TWILIO_WHATSAPP_NUMBER: Twilio Sandbox WhatsApp number (usually same or sandbox number).
# NOTIFY_TARGET_PHONE_NUMBER: Recipient phone number (Safety Officer / Plant Owner).
# ------------------------------------------------------------------------------
TWILIO_PHONE_NUMBER=+12605442983
TWILIO_WHATSAPP_NUMBER=+12605442983
NOTIFY_TARGET_PHONE_NUMBER=+918937967955
